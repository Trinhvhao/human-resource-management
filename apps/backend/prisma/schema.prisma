// =====================================================
// EMPLOYEE PROFILE & DOCUMENTS (NEW)
// =====================================================

model EmployeeProfile {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String @unique @map("employee_id") @db.Uuid

  // Personal Information
  placeOfBirth     String? @map("place_of_birth") @db.VarChar(255)
  nationality      String  @default("Việt Nam") @db.VarChar(100)
  ethnicity        String? @db.VarChar(100)
  religion         String? @db.VarChar(100)
  maritalStatus    String? @map("marital_status") @db.VarChar(50)
  numberOfChildren Int     @default(0) @map("number_of_children")

  // Address Details
  permanentAddress String? @map("permanent_address") @db.Text
  temporaryAddress String? @map("temporary_address") @db.Text

  // Government IDs
  passportNumber String?   @map("passport_number") @db.VarChar(50)
  passportExpiry DateTime? @map("passport_expiry") @db.Date

  // Emergency Contact
  emergencyContactName         String? @map("emergency_contact_name") @db.VarChar(255)
  emergencyContactRelationship String? @map("emergency_contact_relationship") @db.VarChar(100)
  emergencyContactPhone        String? @map("emergency_contact_phone") @db.VarChar(20)
  emergencyContactAddress      String? @map("emergency_contact_address") @db.Text

  // Education
  highestEducation         String? @map("highest_education") @db.VarChar(100)
  major                    String? @db.VarChar(255)
  university               String? @db.VarChar(255)
  graduationYear           Int?    @map("graduation_year")
  professionalCertificates String? @map("professional_certificates") @db.Text

  // Bank Information
  bankName              String? @map("bank_name") @db.VarChar(255)
  bankAccountNumber     String? @map("bank_account_number") @db.VarChar(50)
  bankAccountHolderName String? @map("bank_account_holder_name") @db.VarChar(255)
  bankBranch            String? @map("bank_branch") @db.VarChar(255)

  // Insurance & Tax
  taxCode               String? @map("tax_code") @db.VarChar(20)
  socialInsuranceNumber String? @map("social_insurance_number") @db.VarChar(20)
  healthInsuranceNumber String? @map("health_insurance_number") @db.VarChar(20)
  dependents            Int?    @default(0)

  // Work Experience (before joining company)
  workExperience Json? @map("work_experience")

  // Metadata
  profileCompletionPercentage Int       @default(0) @map("profile_completion_percentage")
  lastProfileUpdate           DateTime? @map("last_profile_update") @db.Timestamp(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

model EmployeeDocument {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId   String   @map("employee_id") @db.Uuid
  documentType String   @map("document_type") @db.VarChar(50)
  fileName     String   @map("file_name") @db.VarChar(255)
  fileUrl      String   @map("file_url") @db.Text
  fileSize     BigInt?  @map("file_size")
  mimeType     String?  @map("mime_type") @db.VarChar(100)
  description  String?  @db.Text
  uploadedAt   DateTime @default(now()) @map("uploaded_at") @db.Timestamp(6)
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploader User?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([documentType])
  @@map("employee_documents")
}

// =====================================================
// EMPLOYEE ACTIVITY LOG - Track all employee activities
// =====================================================

model EmployeeActivity {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String @map("employee_id") @db.Uuid

  // Activity details
  activityType String @map("activity_type") @db.VarChar(100) // 'profile_update', 'attendance', 'leave_request', etc.
  action       String @db.VarChar(50) // 'created', 'updated', 'approved', 'rejected', 'deleted'
  description  String @db.Text // Human-readable description

  // Metadata
  oldValue Json? @map("old_value") // Old value (for updates)
  newValue Json? @map("new_value") // New value (for updates)
  metadata Json? // Additional data (e.g., related IDs, extra info)

  // Who performed the action
  performedBy String? @map("performed_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  employee  Employee @relation("EmployeeActivities", fields: [employeeId], references: [id], onDelete: Cascade)
  performer User?    @relation("PerformedActivities", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([activityType])
  @@index([createdAt(sort: Desc)])
  @@map("employee_activities")
}

// =====================================================
// CONTRACT COMPLIANCE IMPROVEMENTS
// =====================================================

model TerminationRequest {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId          String    @map("contract_id") @db.Uuid
  requestedBy         String    @map("requested_by") @db.Uuid
  terminationCategory String    @map("termination_category") @db.VarChar(50)
  noticeDate          DateTime  @map("notice_date") @db.Date
  terminationDate     DateTime  @map("termination_date") @db.Date
  reason              String    @db.Text
  status              String    @default("PENDING_APPROVAL") @db.VarChar(50)
  approverId          String?   @map("approver_id") @db.Uuid
  approvedAt          DateTime? @map("approved_at") @db.Timestamp(6)
  approverComments    String?   @map("approver_comments") @db.Text
  rejectionReason     String?   @map("rejection_reason") @db.Text
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  requester User     @relation("RequestedTerminations", fields: [requestedBy], references: [id], onDelete: Restrict)
  approver  User?    @relation("ApprovedTerminations", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([contractId])
  @@index([status])
  @@index([terminationDate])
  @@map("termination_requests")
}

model ContractAppendix {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contractId     String   @map("contract_id") @db.Uuid
  appendixNumber String   @map("appendix_number") @db.VarChar(100)
  effectiveDate  DateTime @map("effective_date") @db.Date
  modifiedFields Json     @map("modified_fields") @db.JsonB
  reason         String   @db.Text
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  creator  User     @relation("CreatedAppendices", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([contractId])
  @@index([effectiveDate])
  @@map("contract_appendices")
}

// =====================================================
// WORK CALENDAR & SCHEDULE
// =====================================================

enum ShiftType {
  MORNING // 8:00 - 12:00
  AFTERNOON // 13:00 - 17:00
  FULL_DAY // 8:00 - 17:00
  NIGHT // 18:00 - 22:00
  CUSTOM
}

// Work Schedule for Personal Calendar
model WorkSchedule {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String    @map("employee_id") @db.Uuid
  date       DateTime  @db.Date
  shiftType  ShiftType @default(FULL_DAY) @map("shift_type")
  startTime  DateTime  @map("start_time") @db.Timestamp(6)
  endTime    DateTime  @map("end_time") @db.Timestamp(6)
  isWorkDay  Boolean   @default(true) @map("is_work_day")
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  employee Employee @relation("EmployeeWorkSchedules", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@map("work_schedules")
}

// =====================================================
// COMPANY KNOWLEDGE BASE (for RAG Chatbot)
// =====================================================

model CompanyKnowledge {
  id        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  content   String                      @db.Text
  category  String
  tags      String[]
  embedding Unsupported("vector(384)")?
  metadata  Json?
  isActive  Boolean                     @default(true) @map("is_active")
  createdBy String                      @map("created_by") @db.Uuid
  createdAt DateTime                    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime                    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  creator User @relation("UserKnowledge", fields: [createdBy], references: [id])

  @@index([category])
  @@index([isActive])
  @@index([createdAt])
  @@map("company_knowledge")
}
