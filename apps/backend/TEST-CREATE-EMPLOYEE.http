### Test Create Employee API
### This file tests the employee creation endpoint

### 1. Get a valid department ID first
GET http://localhost:3001/api/departments
Authorization: Bearer YOUR_TOKEN_HERE

### 2. Create a new employee with all required fields
POST http://localhost:3001/api/employees
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "fullName": "Nguyễn Văn Test",
  "email": "test.employee@company.com",
  "phone": "0901234567",
  "dateOfBirth": "1995-05-15",
  "gender": "MALE",
  "idCard": "001234567890",
  "address": "123 Test Street, Hanoi",
  "departmentId": "REPLACE_WITH_VALID_DEPARTMENT_ID",
  "position": "Software Engineer",
  "startDate": "2024-01-01",
  "baseSalary": 15000000
}

### 3. Create employee with minimal required fields only
POST http://localhost:3001/api/employees
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "fullName": "Trần Thị Minimal",
  "email": "minimal.test@company.com",
  "dateOfBirth": "1990-01-01",
  "idCard": "099999999999",
  "departmentId": "REPLACE_WITH_VALID_DEPARTMENT_ID",
  "position": "Tester",
  "startDate": "2024-01-01",
  "baseSalary": 10000000
}

### 4. Test with invalid data - missing required field
POST http://localhost:3001/api/employees
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "fullName": "Missing Email",
  "dateOfBirth": "1990-01-01",
  "idCard": "088888888888",
  "departmentId": "REPLACE_WITH_VALID_DEPARTMENT_ID",
  "position": "Tester",
  "startDate": "2024-01-01",
  "baseSalary": 10000000
}

### 5. Test with invalid gender enum
POST http://localhost:3001/api/employees
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "fullName": "Invalid Gender Test",
  "email": "invalid.gender@company.com",
  "dateOfBirth": "1990-01-01",
  "gender": "Nam",
  "idCard": "077777777777",
  "departmentId": "REPLACE_WITH_VALID_DEPARTMENT_ID",
  "position": "Tester",
  "startDate": "2024-01-01",
  "baseSalary": 10000000
}

### 6. Test with baseSalary = 0
POST http://localhost:3001/api/employees
Content-Type: application/json
Authorization: Bearer YOUR_TOKEN_HERE

{
  "fullName": "Zero Salary Test",
  "email": "zero.salary@company.com",
  "dateOfBirth": "1990-01-01",
  "idCard": "066666666666",
  "departmentId": "REPLACE_WITH_VALID_DEPARTMENT_ID",
  "position": "Intern",
  "startDate": "2024-01-01",
  "baseSalary": 0
}
